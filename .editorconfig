root = true

[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true

[*.go]
indent_style = tab
indent_size = 4

[*.{js,ts,tsx,jsx,css,html,json,yaml,yml}]
indent_style = space
indent_size = 2

[*.md]
trim_trailing_whitespace = false

[*.{sh,bash}]
end_of_line = lf

[*.{bat,cmd,ps1}]
end_of_line = crlf

[Makefile]
indent_style = tab

[go.sum]
insert_final_newline = false
