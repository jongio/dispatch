---
import Base from '../layouts/Base.astro';
import { marked } from 'marked';
import fs from 'node:fs';
import path from 'node:path';

const changelogPath = path.resolve(import.meta.dirname, '../../..', 'CHANGELOG.md');
const raw = fs.readFileSync(changelogPath, 'utf-8');

// Strip the "# Changelog" title and the format preamble.
const lines = raw.split('\n');
const startIdx = lines.findIndex(l => l.startsWith('## '));
const content = lines.slice(startIdx).join('\n');

// Custom renderer to add classes for styling.
const renderer = new marked.Renderer();
renderer.heading = function(token) {
  const text = token.text;
  const depth = token.depth;
  if (depth === 2) {
    // Version headers: extract version and date.
    const match = text.match(/^\[?(v?[\d.]+)\]?\s*(?:[—\-]\s*(.+))?$/);
    if (match) {
      const ver = match[1];
      const date = match[2] || '';
      return `<h2 class="version-header"><span class="version-tag">${ver}</span>${date ? `<span class="version-date">${date}</span>` : ''}</h2>\n`;
    }
    // Unreleased header.
    if (text.toLowerCase().includes('unreleased')) {
      return `<h2 class="version-header"><span class="version-tag unreleased">Unreleased</span></h2>\n`;
    }
    return `<h2 class="version-header">${text}</h2>\n`;
  }
  if (depth === 3) {
    // Category headers: Added, Changed, Fixed, etc.
    const slug = text.toLowerCase().replace(/[^a-z]+/g, '-').replace(/-+$/, '');
    return `<h3 class="category-header category-${slug}">${text}</h3>\n`;
  }
  return `<h${depth}>${text}</h${depth}>\n`;
};

const html = await marked.parse(content, { renderer });
---

<Base title="Changelog — Dispatch">
  <div class="page-header">
    <div class="container">
      <h1>Changelog</h1>
      <p>All notable changes to Dispatch.</p>
    </div>
  </div>

  <section class="section">
    <div class="container changelog-content" set:html={html} />
  </section>
</Base>

<style>
  .changelog-content {
    max-width: 48rem;
  }

  /* Version headers */
  .changelog-content :global(.version-header) {
    display: flex;
    align-items: center;
    gap: var(--space-4);
    margin-top: var(--space-12);
    margin-bottom: var(--space-6);
    padding-bottom: var(--space-4);
    border-bottom: 1px solid var(--border);
  }

  .changelog-content :global(.version-header:first-child) {
    margin-top: 0;
  }

  .changelog-content :global(.version-tag) {
    font-family: var(--font-mono);
    font-size: var(--text-lg);
    font-weight: 700;
    color: var(--accent);
    background: color-mix(in srgb, var(--accent) 10%, transparent);
    padding: var(--space-1) var(--space-3);
    border-radius: var(--radius-md);
    letter-spacing: -0.02em;
  }

  .changelog-content :global(.version-tag.unreleased) {
    color: var(--text-secondary);
    background: color-mix(in srgb, var(--text-secondary) 10%, transparent);
  }

  .changelog-content :global(.version-date) {
    font-size: var(--text-sm);
    color: var(--text-secondary);
    font-weight: 400;
  }

  /* Category headers (Added, Changed, Fixed, etc.) */
  .changelog-content :global(.category-header) {
    font-size: var(--text-base);
    font-weight: 600;
    margin-top: var(--space-6);
    margin-bottom: var(--space-3);
    padding-left: var(--space-3);
    border-left: 3px solid var(--border);
  }

  .changelog-content :global(.category-added) {
    border-left-color: #3fb950;
  }

  .changelog-content :global(.category-changed) {
    border-left-color: #d29922;
  }

  .changelog-content :global(.category-fixed) {
    border-left-color: #58a6ff;
  }

  .changelog-content :global(.category-security) {
    border-left-color: #f85149;
  }

  .changelog-content :global(.category-breaking--------keybinding-overhaul),
  .changelog-content :global([class*="category-breaking"]) {
    border-left-color: #f85149;
  }

  .changelog-content :global(.category-dependencies) {
    border-left-color: #8b949e;
  }

  .changelog-content :global(.category-documentation) {
    border-left-color: #a371f7;
  }

  .changelog-content :global(.category-ci) {
    border-left-color: #8b949e;
  }

  /* List items */
  .changelog-content :global(ul) {
    list-style: none;
    padding: 0;
    margin: 0 0 var(--space-4) 0;
  }

  .changelog-content :global(li) {
    color: var(--text-secondary);
    padding-left: var(--space-6);
    margin-bottom: var(--space-2);
    position: relative;
    font-size: var(--text-sm);
    line-height: var(--leading-relaxed);
  }

  .changelog-content :global(li::before) {
    content: '';
    position: absolute;
    left: var(--space-3);
    top: 0.6em;
    width: 5px;
    height: 5px;
    border-radius: 50%;
    background: var(--text-secondary);
    opacity: 0.4;
  }

  .changelog-content :global(li strong) {
    color: var(--text-primary);
    font-weight: 600;
  }

  .changelog-content :global(li code) {
    font-size: 0.85em;
    background: color-mix(in srgb, var(--text-secondary) 8%, transparent);
    padding: 0.1em 0.4em;
    border-radius: var(--radius-sm);
  }

  /* Horizontal rules between major sections */
  .changelog-content :global(hr) {
    border: none;
    border-top: 1px solid var(--border);
    margin: var(--space-12) 0;
  }
</style>
