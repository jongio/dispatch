{
  "name": "dispatch-electron",
  "version": "0.1.0",
  "description": "Desktop UI for browsing and launching GitHub Copilot CLI sessions",
  "main": "dist/main/index.js",
  "author": "Jon Gallant",
  "license": "MIT",
  "packageManager": "pnpm@10.12.1",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build && electron-builder",
    "build:renderer": "tsc && vite build",
    "start": "electron .",
    "postinstall": "electron-rebuild -m .",
    "rebuild": "electron-rebuild -m .",
    "lint": "eslint src/",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "better-sqlite3": "^11.0.0",
    "chokidar": "^4.0.0",
    "electron-updater": "^6.0.0",
    "zustand": "^5.0.0"
  },
  "devDependencies": {
    "@electron/rebuild": "^4.0.4",
    "@tanstack/react-virtual": "^3.0.0",
    "@types/better-sqlite3": "^7.0.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react": "^4.7.0",
    "autoprefixer": "^10.0.0",
    "electron": "^35.0.0",
    "electron-builder": "^25.0.0",
    "eslint": "^9.0.0",
    "lucide-react": "^0.500.0",
    "postcss": "^8.0.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-markdown": "^9.0.0",
    "remark-gfm": "^4.0.0",
    "tailwindcss": "^4.0.0",
    "tinykeys": "^3.0.0",
    "typescript": "^5.8.0",
    "vite": "^6.0.0",
    "vite-plugin-electron": "^0.28.0",
    "vitest": "^3.0.0"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "better-sqlite3",
      "electron",
      "esbuild"
    ]
  }
}
